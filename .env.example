# ────────────────────────────────────────────────────
# ProvenanceAI — Root .env.example
# Copy this file and fill in your values.
# DO NOT commit your real .env files to source control.
# ────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ──────────────────────
# Get this from https://neon.tech — connection string with pooling
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Clerk Authentication ────────────────────────────
# Get from https://clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here

# ── Resend Email (for staleness alerts) ─────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=alerts@your-domain.com
RESEND_TO_EMAIL=your-email@example.com

# ── CORS (comma-separated list of allowed origins) ──
# In production, set this to your Vercel frontend URL
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# ── Backend Settings ─────────────────────────────────
# Set SKIP_AUTH=true only for local development without Clerk
SKIP_AUTH=false
# Staleness check interval in hours (default: 24)
STALENESS_CHECK_INTERVAL_HOURS=24
# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
