# ──────────────────────────────────────────────────────────────────────────────
# ProvenanceAI — Root .env.example
# Copy this file to .env and fill in your values.
# DO NOT commit your real .env files to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Get this from https://neon.tech — use the pooled connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get from https://clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here

# Set to true only for local development without Clerk
# MUST be false in production
SKIP_AUTH=false

# ── Resend Email (for incident alerts) ────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here
ALERT_EMAIL_FROM=alerts@your-domain.com
ALERT_EMAIL_TO=your-email@example.com

# ── Slack Alerts ──────────────────────────────────────────────────────────────
# Get from: Slack → Apps → Incoming Webhooks → Add to Slack
# Leave empty to disable Slack alerts
SLACK_WEBHOOK_URL=

# ── CORS (comma-separated list of allowed origins) ───────────────────────────
# In production, set this to your Vercel frontend URL
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used in alert email/Slack links back to the dashboard
APP_URL=http://localhost:3000

# ── Backend Settings ──────────────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Staleness check interval in hours (default: 24)
STALENESS_CHECK_INTERVAL_HOURS=24

# ── Semantic Diff Thresholds ──────────────────────────────────────────────────
# Controls how the Remediation Engine classifies content changes.
# Higher values = more sensitive (more incidents). Lower = less sensitive.
# FORMATTING: near-identical, just whitespace/punctuation changes
# ADDITIVE: new content appended, existing content unchanged
# MODIFIED: meaningful content changes, may affect downstream answers
SEMANTIC_DIFF_THRESHOLD_FORMATTING=0.95
SEMANTIC_DIFF_THRESHOLD_ADDITIVE=0.70
SEMANTIC_DIFF_THRESHOLD_MODIFIED=0.40

# ── Next.js Frontend (set in Vercel or web/.env.local) ────────────────────────
# NEXT_PUBLIC_API_URL=https://provenance-ai.onrender.com
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_key_here
