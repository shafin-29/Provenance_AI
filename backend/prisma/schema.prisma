generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model SourceRecord {
  id                  String               @id @default(cuid())
  sourceId            String
  contentHash         String
  versionTs           DateTime
  pipelineId          String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isStale             Boolean              @default(false)
  isQuarantined       Boolean              @default(false)
  pendingReingest     Boolean              @default(false)
  contentPreview      String?
  transformationSteps TransformationStep[]
  embeddings          Embedding[]
  stalenessAlerts     StalenessAlert[]
  quarantineRecords   QuarantineRecord[]
  incidents           Incident[]
}

model TransformationStep {
  id             String       @id @default(cuid())
  sourceRecordId String
  sourceRecord   SourceRecord @relation(fields: [sourceRecordId], references: [id])
  operatorName   String
  inputHash      String
  outputHash     String
  appliedAt      DateTime
}

model Embedding {
  id                   String                    @id @default(cuid())
  chunkIndex           Int
  parentSourceRecordId String
  parentSourceRecord   SourceRecord              @relation(fields: [parentSourceRecordId], references: [id])
  vectorDbId           String
  embeddingModel       String
  isStale              Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  retrievalEvents      RetrievalEventEmbedding[]
}

model RetrievalEvent {
  id              String                    @id @default(cuid())
  sessionId       String
  queryText       String
  retrievedAt     DateTime                  @default(now())
  embeddings      RetrievalEventEmbedding[]
  promptContexts  PromptContext[]
}

model RetrievalEventEmbedding {
  id               String         @id @default(cuid())
  retrievalEventId String
  retrievalEvent   RetrievalEvent @relation(fields: [retrievalEventId], references: [id])
  embeddingId      String
  embedding        Embedding      @relation(fields: [embeddingId], references: [id])
}

model PromptContext {
  id               String         @id @default(cuid())
  retrievalEventId String
  retrievalEvent   RetrievalEvent @relation(fields: [retrievalEventId], references: [id])
  promptHash       String
  assembledAt      DateTime       @default(now())
  llmResponses     LLMResponse[]
}

model LLMResponse {
  id              String        @id @default(cuid())
  promptContextId String
  promptContext   PromptContext @relation(fields: [promptContextId], references: [id])
  responseText    String
  responseHash    String
  modelVersion    String
  respondedAt     DateTime      @default(now())
}

model StalenessAlert {
  id               String        @id @default(cuid())
  sourceRecordId   String
  sourceRecord     SourceRecord  @relation(fields: [sourceRecordId], references: [id])
  detectedAt       DateTime      @default(now())
  previousHash     String
  currentHash      String
  embeddingsMarked Int
  resolvedAt       DateTime?
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  pipelineId  String
  clerkUserId String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
}

model ShieldEvent {
  id         String    @id @default(cuid())
  eventType  String
  pipelineId String
  sessionId  String
  sourceId   String
  payload    Json
  createdAt  DateTime  @default(now())
  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])
}

model QuarantineRecord {
  id             String       @id @default(cuid())
  sourceRecordId String
  sourceRecord   SourceRecord @relation(fields: [sourceRecordId], references: [id])
  reason         String
  quarantinedAt  DateTime     @default(now())
  restoredAt     DateTime?
  quarantinedBy  String
}

model Incident {
  id                 String       @id @default(cuid())
  sourceRecordId     String
  sourceRecord       SourceRecord @relation(fields: [sourceRecordId], references: [id])

  status             String       @default("active")
  // active | resolved | acknowledged

  severity           String       @default("medium")
  // low | medium | high | critical

  changeType         String?
  // FORMATTING | ADDITIVE | MODIFIED | CONTRADICTORY

  semanticDiffScore  Float?
  // 0.0 to 1.0 — higher = more similar (less change)

  action             String?
  // LOW_PRIORITY_ALERT | MONITOR | QUARANTINE_AND_REINGEST | EMERGENCY_QUARANTINE

  embeddingsAffected Int          @default(0)
  blastRadius        Int          @default(0)
  // count of LLM responses that used stale data

  alertSent          Boolean      @default(false)
  alertSentAt        DateTime?

  resolvedAt         DateTime?
  resolvedBy         String?
  // "automatic" | "manual" | "reingest"

  notes              String?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  shieldEvents       ShieldEvent[]
}
