# ──────────────────────────────────────────────────────────────────────────────
# ProvenanceAI Backend — .env.example
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Database (Neon PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk Authentication (from https://clerk.com → API Keys)
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here

# Set to true only for local dev without Clerk
SKIP_AUTH=false

# Resend email service (from https://resend.com)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=alerts@your-domain.com
RESEND_TO_EMAIL=your-email@example.com

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Staleness check interval in hours (default: 24)
STALENESS_CHECK_INTERVAL_HOURS=24

# Slack Incoming Webhook for incident alerts
# Get from: Slack → Apps → Incoming Webhooks → Add to Slack
# Leave empty to disable Slack alerts
SLACK_WEBHOOK_URL=

# Semantic Diff Thresholds (adjust to tune alert sensitivity)
# Higher values = more sensitive (more alerts)
# Lower values = less sensitive (fewer alerts)
SEMANTIC_DIFF_THRESHOLD_FORMATTING=0.95
SEMANTIC_DIFF_THRESHOLD_ADDITIVE=0.70
SEMANTIC_DIFF_THRESHOLD_MODIFIED=0.40

# Frontend URL (used in alert links)
APP_URL=http://localhost:3000

